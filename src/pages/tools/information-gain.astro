// Note: the layout import path should match your Astro project structure.
// For standalone development, this page can be self-contained.
---

<!-- IMPORTANT: Replace __TURNSTILE_SITE_KEY__ with your actual Turnstile site key or use Astro env: import.meta.env.PUBLIC_TURNSTILE_SITE_KEY -->
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Information Gain Tool</title>
</head>
<body class="bg-cream-200 text-warm-800 dark:bg-warm-950 dark:text-cream-200 font-body antialiased">
<div class="px-5 sm:mx-auto sm:max-w-2xl sm:px-8 lg:px-0 md:max-w-6xl grid gap-12 mt-4">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-12">

    <header class="text-center mb-12 pb-8 border-b-2 border-amber-300 dark:border-amber/20">
      <h1 class="text-3xl font-bold">Information Gain Tool</h1>
      <p class="mt-3 text-sm text-warm-700 dark:text-cream-300 max-w-xl mx-auto leading-relaxed">
        This demo draws from a curated set of research reports on AI and LLM security. The tool injects novel data points from these reports into the selected article.
      </p>
      <ul class="mt-4 text-sm text-warm-600 dark:text-cream-400 max-w-xl mx-auto text-left space-y-1 list-disc pl-5 leading-relaxed">
          <li><a href="https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-2e2025.pdf" target="_blank" class="text-amber hover:underline">NIST AI Risk Management Framework (AI 100-2e)</a></li>
          <li><a href="https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.800-4.pdf" target="_blank" class="text-amber hover:underline">NIST AI Security and Privacy (AI 800-4)</a></li>
          <li><a href="https://genai.owasp.org/resource/owasp-top-10-for-llm-applications-2025/" target="_blank" class="text-amber hover:underline">OWASP Top 10 for LLM Applications</a></li>
          <li><a href="https://arxiv.org/abs/2604.04288" target="_blank" class="text-amber hover:underline">LLM-Enabled Open-Source Systems in the Wild: An Empirical Study</a></li>
          <li><a href="https://arxiv.org/abs/2603.22489" target="_blank" class="text-amber hover:underline">Model Context Protocol Threat Modeling &amp; Prompt Injection Analysis</a></li>
          <li><a href="https://www.techrxiv.org/doi/full/10.36227/techrxiv.176773228.86819800" target="_blank" class="text-amber hover:underline">Jailbreaking LLMs: A Survey of Attacks, Defenses and Evaluation</a></li>
        </ul>
    </header>

    <form id="enrich-form" class="bg-cream-100 dark:bg-warm-850 border border-cream-400 dark:border-warm-800 rounded-lg p-6 sm:p-10 shadow-sm" onsubmit="return false">
      <div class="mb-6">
        <label for="article-url" class="block text-sm font-medium text-warm-800 dark:text-cream-200 mb-2">
          Article
        </label>
        <select
          id="article-url"
          required
          class="w-full px-4 py-3 border border-cream-400 dark:border-warm-700 rounded-md text-sm bg-cream-100 text-warm-900 dark:bg-cream-100 dark:text-warm-900 focus:outline-none focus:ring-2 focus:ring-amber dark:focus:ring-amber-bright focus:border-transparent appearance-none"
        >
          <option value="">Select an article...</option>
          <option value="https://launchdarkly.com/blog/llm-observability/">LaunchDarkly — LLM Observability</option>
          <option value="https://www.cloudflare.com/the-net/vulnerable-llm-ai/">Cloudflare — The Vulnerable LLM in AI</option>
          <option value="https://www.checkpoint.com/cyber-hub/cyber-security/what-is-ai-security/ai-agent-security/">Check Point — AI Agent Security</option>
          <option value="https://www.obsidiansecurity.com/blog/security-for-ai-agents">Obsidian Security — Security for AI Agents</option>
          <option value="https://www.paloaltonetworks.com/cyberpedia/what-is-agentic-ai-security">Palo Alto Networks — What Is Agentic AI Security</option>
        </select>
        <input type="text" id="selected-url" readonly class="w-full px-4 py-2 border border-cream-300 dark:border-warm-700 rounded-md text-xs bg-cream-200 dark:bg-warm-900 text-warm-500 dark:text-cream-500 mt-2" placeholder="Select an article to see its URL" />
        <p class="text-xs text-warm-700/60 dark:text-cream-400/60 mt-1">
          Choose an article from the list above.
        </p>
      </div>

      <div class="mb-8">
        <div class="cf-turnstile" data-sitekey="0x4AAAAAADTd6rvtgyCPooVS" data-error-callback="onTurnstileError"></div>
      </div>

      <button
        id="run-btn"
        type="button"
        class="w-full py-3 px-6 bg-amber dark:bg-amber-bright text-cream-50 dark:text-warm-900 rounded-md font-semibold text-base hover:bg-amber/90 dark:hover:bg-amber-bright/90 active:scale-[0.99] transition-all focus:outline-none focus:ring-2 focus:ring-amber dark:focus:ring-amber-bright focus:ring-offset-2 dark:focus:ring-offset-warm-900 min-h-[48px]"
      >
        Run Enrichment &rarr;
      </button>


      <div id="progress-area" class="hidden mt-6 p-4 bg-cream-200 dark:bg-warm-800 rounded-lg">
        <div id="progress-list" class="flex flex-col gap-2 text-sm"></div>
      </div>
    </form>

    <div id="results-area" class="hidden mt-8"></div>

  </div>
</div>

<script src="/scripts/information-gain.js"></script>
</body>
</html>
